<% content_for :title, "Health" %>
<% content_for :turbo_cache_control, "no-cache" %>

<h1>Integration Console</h1>

<%= svelte_bundle_tags :dashboard_cards %>

<div id="dashboard-cards-svelte-root"></div>
<%= svelte_props_tag "dashboard-cards-svelte-root", { initial: @dashboard_cards_payload || { endpoint: health_cards_path(format: :json) } } %>

<section class="grid grid-3 section-spaced">
  <div id="live-feed-panel-svelte-root"></div>
  <%= svelte_props_tag "live-feed-panel-svelte-root", { initial: { recentUrl: recent_audit_logs_path(format: :json) } } %>
  <div id="nats-throughput-svelte-root"></div>
  <%= svelte_props_tag "nats-throughput-svelte-root", { initial: { endpoint: health_nats_samples_path(format: :json) } } %>
  <div id="recent-alerts-svelte-root"></div>
  <%= svelte_props_tag "recent-alerts-svelte-root", { initial: { endpoint: health_recent_alerts_path(format: :json) } } %>
</section>

<div id="threat-alerts-panel-svelte-root"></div>
<%= svelte_props_tag "threat-alerts-panel-svelte-root", { initial: { endpoint: alerts_path(format: :json) } } %>

<div id="sync-health-svelte-root"></div>
<%= svelte_props_tag "sync-health-svelte-root", { initial: { endpoint: health_sync_data_path(format: :json) } } %>

<div id="sensors-panel-svelte-root"></div>
<%= svelte_props_tag "sensors-panel-svelte-root", { initial: { endpoint: health_sensors_path(format: :json) } } %>
