<% content_for :title, "Audit Logs" %>
<% content_for :turbo_cache_control, "no-cache" %>

<%= svelte_props_tag("audit-log-svelte-root", initial: @audit_log_payload) %>
<div id="audit-log-svelte-root"></div>
<%= svelte_bundle_tags(:audit_logs) %>

<noscript>
  <h1>Audit Logs</h1>
  <p><%= link_to "Export CSV", export_audit_logs_path(request.query_parameters) %></p>
  <div class="data-table-wrap table-wrap">
    <table class="data-table audit-log-table">
      <thead>
        <tr>
          <th class="col-observed">Observed</th>
          <th class="col-sensor">Sensor</th>
          <th class="col-location">Location</th>
          <th class="col-subtype">Subtype</th>
          <th class="col-ssid">SSID</th>
          <th class="col-source">Source</th>
          <th class="col-dest">Dest BSSID</th>
          <th class="col-signal">Signal</th>
          <th class="col-bytes">Bytes</th>
          <th class="col-flags">Flags</th>
          <th class="col-security">Security</th>
          <th class="col-fp">Fingerprint</th>
          <th class="col-hs">Handshake</th>
        </tr>
      </thead>
      <tbody>
        <% if @audit_logs.any? %>
          <% @audit_logs.each do |entry| %>
            <%= render "row", entry: entry %>
          <% end %>
        <% else %>
          <tr>
            <td colspan="13" class="empty-state">No audit logs found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= render "shared/pagination" %>
  </div>
</noscript>
