<%= form_with model: device do |form| %>
  <% if device.errors.any? %>
    <div class="status-alert"><%= device.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="form-grid">
    <div>
      <%= form.label :display_name, "Device" %>
      <%= form.text_field :display_name, placeholder: "Lobby printer" %>
    </div>
    <div>
      <%= form.label :username, "Owner" %>
      <%= form.text_field :username, placeholder: "jane.doe" %>
    </div>
    <div>
      <%= form.label :mac_hint, "MAC" %>
      <%= form.text_field :mac_hint, placeholder: "10:20:30:40:50:60" %>
    </div>
    <div>
      <%= form.label :hostname %>
      <%= form.text_field :hostname, placeholder: "printer-lobby" %>
    </div>
    <div>
      <%= form.label :os_hint, "OS" %>
      <%= form.text_field :os_hint, placeholder: "iOS, macOS, printer" %>
    </div>
  </div>

  <div>
    <%= form.label :notes %>
    <%= form.text_area :notes, rows: 3 %>
  </div>

  <%= form.submit %>
<% end %>
