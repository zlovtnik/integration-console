<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= page_title %></title>
    <% if content_for?(:turbo_cache_control) %>
      <meta name="turbo-cache-control" content="<%= content_for(:turbo_cache_control) %>">
    <% end %>
    <meta name="view-transition" content="same-origin">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= vite_client_tag %>
    <%= vite_stylesheet_tag "application", "data-turbo-track": "reload" %>
    <%= vite_javascript_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body data-controller="turbo-loading">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="turbo-loading-bar" aria-hidden="true"></div>
    <div class="app-shell" data-controller="sidebar" data-action="keydown.esc@window->sidebar#close">
      <aside id="main-sidebar" class="sidebar" aria-label="Main navigation" data-sidebar-target="panel">
        <div class="sidebar-title">Integration Console</div>
        <nav class="side-nav" aria-label="Primary">
          <%= nav_link_to "Health", root_path, icon: :health %>
          <%= nav_link_to "Audit Logs", audit_logs_path, icon: :audit %>
          <%= nav_link_to "Integrations", integrations_path, icon: :integration %>
          <%= nav_link_to "Backlog", backlog_index_path, icon: :backlog %>
          <%= nav_link_to "Audit Windows", audit_windows_path, icon: :windows %>
          <%= nav_link_to "Authorized Wireless", wireless_authorized_networks_path, icon: :wireless %>
          <%= nav_link_to "MAC Identifiers", devices_path, icon: :devices %>
          <%= nav_link_to "Identities", identities_path, icon: :identities %>
          <%= nav_link_to "Network Clients", wireless_clients_path, icon: :wireless %>
          <%= nav_link_to "Fingerprint Sources", fingerprint_sources_path, icon: :fingerprint %>
          <%= nav_link_to "Heatmap", heatmap_index_path, icon: :heatmap %>
          <%= nav_link_to "Alerts", alerts_path, icon: :alerts %>
          <%= nav_link_to "Shadow IT", wireless_shadow_alerts_path, icon: :alerts %>
        </nav>
      </aside>
      <div class="sidebar-overlay" data-sidebar-target="overlay" data-action="click->sidebar#close"></div>
      <main id="main-content" class="main-content" tabindex="-1">
        <header class="main-header">
          <button id="sidebar-toggle" class="sidebar-toggle" type="button" aria-expanded="false" aria-controls="main-sidebar" data-sidebar-target="toggle" data-action="click->sidebar#toggle">
            <span class="hamburger" aria-hidden="true"></span>
            <span class="visually-hidden">Toggle navigation</span>
          </button>
        </header>
        <% if notice.present? %><p class="status-ok flash-message" data-controller="flash" role="status" aria-live="polite"><%= notice %></p><% end %>
        <% if alert.present? %><p class="status-alert flash-message" data-controller="flash" role="alert" aria-live="assertive"><%= alert %></p><% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
