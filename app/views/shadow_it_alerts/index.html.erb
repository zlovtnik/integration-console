<% content_for :title, "Shadow IT Alerts" %>
<% content_for :turbo_cache_control, "no-cache" %>

<h1>Shadow IT Alerts</h1>

<%= svelte_props_tag("shadow-it-alerts-svelte-root", initial: { filters: parsed_grid_filters }) %>
<div id="shadow-it-alerts-svelte-root"></div>
<%= svelte_bundle_tags(:shadow_it_alerts) %>

<div
  class="data-table-wrap table-wrap"
  data-controller="mac-link"
  data-mac-link-inventory-url-value="<%= inventory_identities_path(format: :json) %>"
  data-mac-link-summary-url-value="<%= mac_summary_identities_path(format: :json) %>"
  data-mac-link-recent-audit-logs-url-value="<%= recent_audit_logs_path %>"
  data-mac-link-audit-logs-url-value="<%= audit_logs_path %>"
  data-mac-link-identities-url-value="<%= identities_path %>"
  data-mac-link-shadow-it-url-value="<%= shadow_it_alerts_path %>"
>
  <table class="data-table">
    <thead>
      <tr>
        <th><%= sort_link_to "Last Occurred", :last_occurred_at %></th>
        <th><%= sort_link_to "Source MAC", :source_mac %></th>
        <th><%= sort_link_to "Dest BSSID", :destination_bssid %></th>
        <th><%= sort_link_to "SSID", :ssid %></th>
        <th><%= sort_link_to "Sensor", :sensor_id %></th>
        <th><%= sort_link_to "Location", :location_id %></th>
        <th><%= sort_link_to "Signal", :signal_dbm %></th>
        <th><%= sort_link_to "Reason", :reason %></th>
        <th><%= sort_link_to "Resolved", :resolved_at %></th>
      </tr>
    </thead>
    <tbody>
      <% if @shadow_it_alerts.any? %>
        <% @shadow_it_alerts.each do |alert| %>
          <tr>
            <td><%= alert.last_occurred_at %></td>
            <td><%= display_mac(alert.source_mac) %></td>
            <td><%= display_mac(alert.destination_bssid) %></td>
            <td><%= alert.ssid %></td>
            <td><%= alert.sensor_id %></td>
            <td><%= alert.location_id %></td>
            <td><%= alert.signal_dbm %></td>
            <td><%= alert.reason %></td>
            <td><%= alert.resolved_at %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="9" class="empty-state">No shadow IT alerts found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= render "shared/pagination" %>
</div>
